# Supabase (kostenlos: supabase.com → New Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OpenRouter API (openrouter.ai → Keys)
OPENROUTER_API_KEY=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

# LLM Modell (optional, default: google/gemini-2.5-flash)
# Alternativen: anthropic/claude-3-haiku, meta-llama/llama-3-8b-instruct
LLM_MODEL=google/gemini-2.5-flash

# App URL (für OpenRouter Referer Header)
NEXT_PUBLIC_APP_URL=https://trading-advisor.vercel.app

# Web Push VAPID Keys (npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dein@email.de

# Cron Secret (beliebiger String)
CRON_SECRET=dein-geheimer-cron-key
